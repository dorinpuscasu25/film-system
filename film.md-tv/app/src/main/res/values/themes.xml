<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AppCompat parent is required by the Bunny player's Cast button
         (MediaRouteButton). All colours are opaque so MediaRouter's contrast
         calculation doesn't crash ("background can not be translucent"). -->
    <style name="Theme.FilmotecaTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/background</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
</resources>
